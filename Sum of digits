#include<stdio.h>
int main()
{
   long long int a,sum=0;
   printf("Enter a number:");
   scanf("%lld",&a);
   while(a>0)
   {
      sum=sum+(a%10);
      a=a/10;
   }
   printf("The sum of the digits is %lld",sum);
   return 0;
}
